# Supabase → Project Settings → Database → URI (use the pooled string)
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Groq (used for both STT and LLM) — https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Sarvam AI (TTS tier 1) — https://dashboard.sarvam.ai
SARVAM_API_KEY=...
SARVAM_TTS_MODEL=bulbul:v3

# Azure Speech (TTS tier 2, fallback) — leave blank to skip
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=centralindia

# Piper (TTS tier 3, free local, optional) — leave blank to skip
PIPER_BINARY=piper
PIPER_VOICE_DIR=/opt/piper-voices